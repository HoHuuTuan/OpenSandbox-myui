#!/bin/sh
set -eu

BROKER_URL="${OPENCLAW_DATA_BROKER_URL:-http://host.docker.internal:3302}"
BROKER_TOKEN="${OPENCLAW_DATA_BROKER_TOKEN:-broker-secret}"

usage() {
  cat <<'EOF'
Usage:
  broker-query schema
  broker-query customer-profile <customer-id>
  broker-query customer-orders <customer-id> [limit]
  broker-query account-summary <account-id>
EOF
}

request() {
  path="$1"
  output="$(curl -fsS \
    -H "Authorization: Bearer ${BROKER_TOKEN}" \
    -H "Accept: application/json" \
    "${BROKER_URL}${path}")"

  if command -v jq >/dev/null 2>&1; then
    printf '%s\n' "${output}" | jq .
  else
    printf '%s\n' "${output}"
  fi
}

command_name="${1:-}"

case "${command_name}" in
  schema)
    request "/v1/schema"
    ;;
  customer-profile)
    customer_id="${2:-}"
    [ -n "${customer_id}" ] || { usage; exit 1; }
    request "/v1/customers/${customer_id}/profile"
    ;;
  customer-orders)
    customer_id="${2:-}"
    limit="${3:-5}"
    [ -n "${customer_id}" ] || { usage; exit 1; }
    request "/v1/customers/${customer_id}/orders?limit=${limit}"
    ;;
  account-summary)
    account_id="${2:-}"
    [ -n "${account_id}" ] || { usage; exit 1; }
    request "/v1/accounts/${account_id}/summary"
    ;;
  *)
    usage
    exit 1
    ;;
esac
